# Credenciais do Instagram — todas obrigatórias.
# Obtenha-as pelo browser após fazer login no instagram.com:
# 1. Abra https://www.instagram.com no Chrome e faça login
# 2. Pressione F12 → Application → Storage → Cookies → https://www.instagram.com
# 3. Copie o Value de cada cookie listado abaixo

# Cookie: sessionid
INSTAGRAM_SESSION_ID=seu_session_id_aqui

# Cookie: csrftoken
INSTAGRAM_CSRF_TOKEN=seu_csrf_token_aqui

# Cookie: ds_user_id
INSTAGRAM_DS_USER_ID=seu_ds_user_id_aqui
